<?xml version="1.0" encoding="utf-8"?>
<!--
    Paramètres système payment_djomy — défauts sécurisés upstream.

    noupdate="1" : ne pas écraser une valeur configurée par l'admin
    lors d'un `-u payment_djomy`. La désactivation de la vérification
    HMAC (par exemple parce que Djomy ne signe pas correctement les
    notifications) se fait via UI / shell / un autre module.
-->
<odoo noupdate="1">

    <!--
        Vérification HMAC du webhook Djomy.
          - True  : signature obligatoire (défaut sécurisé).
          - False : signature ignorée — le controller compense en
                    interrogeant `GET /payments/{id}/status` côté
                    Djomy pour récupérer le statut officiel avant de
                    transitionner la transaction.
    -->
    <record id="icp_djomy_webhook_verify_signature" model="ir.config_parameter">
        <field name="key">djomy.webhook_verify_signature</field>
        <field name="value">True</field>
    </record>

    <!--
        Délai (en minutes) au-delà duquel une transaction Djomy
        restée en `pending` est annulée automatiquement par le cron
        `ir_cron_djomy_cancel_stale_pending`. Par défaut 120 min (2h).
        Mettre `0` désactive le cancel forcé (le cron ne fait rien).
    -->
    <record id="icp_djomy_pending_auto_cancel_minutes" model="ir.config_parameter">
        <field name="key">djomy.pending_auto_cancel_minutes</field>
        <field name="value">120</field>
    </record>

</odoo>
